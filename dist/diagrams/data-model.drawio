  <diagram id="data-model" name="Data Model (Firestore ERD)">
    <mxGraphModel dx="1422" dy="900" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1600" pageHeight="1000" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />

        <!-- Title -->
        <mxCell id="title" value="MOOVIZ — Firestore Data Model (ERD)" style="text;html=1;fontSize=22;fontStyle=1;align=center;verticalAlign=middle;whiteSpace=wrap;fontColor=#333333;" vertex="1" parent="1">
          <mxGeometry x="400" y="20" width="600" height="40" as="geometry" />
        </mxCell>

        <!-- ==================== USERS COLLECTION ==================== -->
        <mxCell id="users-header" value="users/{userId}" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#1A73E8;fontColor=#FFFFFF;fontSize=14;fontStyle=1;strokeColor=#1557B0;verticalAlign=middle;" vertex="1" parent="1">
          <mxGeometry x="80" y="100" width="300" height="36" as="geometry" />
        </mxCell>
        <mxCell id="users-body" value="uid: string (PK)&#xa;fullName: string&#xa;phone: string (E.164)&#xa;email?: string&#xa;city: string&#xa;role: 'sender' | 'driver'&#xa;profilePhotoURL: string&#xa;kycDocumentURL: string&#xa;kycStatus: 'pending' | 'approved' | 'rejected'&#xa;driverUnlocked: boolean&#xa;rating: { average: number, count: number }&#xa;completedDeliveries: number&#xa;status: 'active' | 'suspended' | 'blocked'&#xa;fcmTokens: string[]&#xa;location: { lat, lng, geohash }&#xa;driverAvailable: boolean&#xa;acceptedSizes: string[]&#xa;createdAt: Timestamp&#xa;updatedAt: Timestamp" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#E8F0FE;fontColor=#333333;fontSize=10;strokeColor=#1557B0;align=left;spacingLeft=10;verticalAlign=top;spacingTop=6;" vertex="1" parent="1">
          <mxGeometry x="80" y="136" width="300" height="310" as="geometry" />
        </mxCell>

        <!-- ==================== DELIVERIES COLLECTION ==================== -->
        <mxCell id="del-header" value="deliveries/{deliveryId}" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#D2AC47;fontColor=#FFFFFF;fontSize=14;fontStyle=1;strokeColor=#B8952E;verticalAlign=middle;" vertex="1" parent="1">
          <mxGeometry x="520" y="100" width="340" height="36" as="geometry" />
        </mxCell>
        <mxCell id="del-body" value="deliveryId: string (PK)&#xa;senderId: string (FK → users)&#xa;driverId?: string (FK → users)&#xa;status: DeliveryStatus&#xa;pickup: { address, city, lat, lng, geohash }&#xa;destination: { address, city, lat, lng, geohash }&#xa;item: { description, type, size, photoURL }&#xa;price: number (NIS)&#xa;pickupDate: Timestamp | 'asap'&#xa;notes?: string&#xa;payment: { senderConfirmed, driverConfirmed }&#xa;proof: { pickupURL?, deliveryURL?, paymentURL? }&#xa;statusHistory: StatusEntry[]&#xa;interestedDrivers: string[]&#xa;selectedDriverId?: string&#xa;cancelledBy?: string&#xa;cancelReason?: string&#xa;notifiedDrivers: string[]&#xa;notifyRadius: number&#xa;notifyExpansionCount: number&#xa;lastNotifyExpansion: Timestamp&#xa;timeoutAt: Timestamp&#xa;createdAt: Timestamp&#xa;updatedAt: Timestamp" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#FFF8E1;fontColor=#333333;fontSize=10;strokeColor=#B8952E;align=left;spacingLeft=10;verticalAlign=top;spacingTop=6;" vertex="1" parent="1">
          <mxGeometry x="520" y="136" width="340" height="380" as="geometry" />
        </mxCell>

        <!-- ==================== CHATS COLLECTION ==================== -->
        <mxCell id="chats-header" value="chats/{deliveryId}" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#34A853;fontColor=#FFFFFF;fontSize=14;fontStyle=1;strokeColor=#2D8F47;verticalAlign=middle;" vertex="1" parent="1">
          <mxGeometry x="1000" y="100" width="260" height="36" as="geometry" />
        </mxCell>
        <mxCell id="chats-body" value="deliveryId: string (PK)&#xa;participants: string[] (userIds)&#xa;senderId: string (FK → users)&#xa;driverId: string (FK → users)&#xa;lastMessage: string&#xa;lastMessageAt: Timestamp&#xa;closedAt?: Timestamp&#xa;closedReason?: string&#xa;createdAt: Timestamp" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#E8F5E9;fontColor=#333333;fontSize=10;strokeColor=#2D8F47;align=left;spacingLeft=10;verticalAlign=top;spacingTop=6;" vertex="1" parent="1">
          <mxGeometry x="1000" y="136" width="260" height="160" as="geometry" />
        </mxCell>

        <!-- MESSAGES SUBCOLLECTION -->
        <mxCell id="messages-header" value="messages/{messageId}" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#66BB6A;fontColor=#FFFFFF;fontSize=12;fontStyle=1;strokeColor=#2D8F47;verticalAlign=middle;" vertex="1" parent="1">
          <mxGeometry x="1040" y="330" width="220" height="30" as="geometry" />
        </mxCell>
        <mxCell id="messages-body" value="messageId: string (PK)&#xa;senderId: string (FK → users)&#xa;text: string&#xa;type: 'text' | 'location' | 'system'&#xa;location?: { lat, lng }&#xa;readBy: string[]&#xa;createdAt: Timestamp" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#F1F8E9;fontColor=#333333;fontSize=10;strokeColor=#2D8F47;align=left;spacingLeft=10;verticalAlign=top;spacingTop=6;" vertex="1" parent="1">
