        <mxCell id="admin-body" value="actionId: string (PK)&#xa;adminId: string (FK → users)&#xa;targetUserId?: string (FK → users)&#xa;targetDeliveryId?: string (FK → deliveries)&#xa;action: string&#xa;reason: string&#xa;createdAt: Timestamp" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#F5F5F5;fontColor=#333333;fontSize=10;strokeColor=#757575;align=left;spacingLeft=10;verticalAlign=top;spacingTop=6;" vertex="1" parent="1">
          <mxGeometry x="760" y="606" width="260" height="130" as="geometry" />
        </mxCell>

        <!-- ==================== RELATIONSHIPS ==================== -->

        <!-- users 1→N deliveries (as sender) -->
        <mxCell id="rel-sender" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;strokeColor=#1A73E8;strokeWidth=2;endArrow=ERmany;endFill=0;startArrow=ERone;startFill=0;" edge="1" parent="1" source="users-body" target="del-body">
          <mxGeometry relative="1" as="geometry">
