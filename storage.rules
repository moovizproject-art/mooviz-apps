rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {

    // Max file size: 5MB
    function maxSize() {
      return 5 * 1024 * 1024;
    }

    // Only image content types
    function isImage() {
      return request.resource.contentType.matches('image/.*');
    }

    // Images + video (for multi-media delivery uploads)
    function isMedia() {
      return request.resource.contentType.matches('image/.*')
          || request.resource.contentType.matches('video/mp4')
          || request.resource.contentType.matches('video/quicktime');
    }

    function isAuthenticated() {
      return request.auth != null;
    }

    function isAdmin() {
      return request.auth != null
        && firestore.get(/databases/(default)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }

    // Check if caller is a participant (sender or driver) of a delivery
    function isDeliveryParticipant(deliveryId) {
      let delivery = firestore.get(/databases/(default)/documents/deliveries/$(deliveryId));
      return delivery.data.senderId == request.auth.uid
          || delivery.data.driverId == request.auth.uid;
    }

    // Check if caller is a chat participant
    function isChatParticipant(chatId) {
      let chat = firestore.get(/databases/(default)/documents/chats/$(chatId));
      return request.auth.uid in chat.data.participants;
    }

    // ───────────────────────────────────────────────
    // Profile Photos — Encrypted at rest
    // Owner uploads raw to temp path, Cloud Function encrypts.
    // Encrypted file (profile.enc) readable only by admin SDK.
    // ───────────────────────────────────────────────
    match /users/{userId}/profile-temp.jpg {
      // Owner can upload the temp file (Cloud Function picks it up)
      allow write: if isAuthenticated()
        && request.auth.uid == userId
        && isImage()
        && request.resource.size < maxSize();
      // No direct read — Cloud Function handles via admin SDK
      allow read: if false;
    }

    // Profile photo — direct upload (before encryption Cloud Functions are deployed)
    match /users/{userId}/profile.jpg {
      // Owner or admin can read
      allow read: if isAuthenticated()
        && (request.auth.uid == userId || isAdmin());
      allow write: if isAuthenticated()
        && request.auth.uid == userId
        && isImage()
        && request.resource.size < maxSize();
    }

    match /users/{userId}/profile.enc {
      // Encrypted files: no client read/write
      // Only Cloud Functions (admin SDK) access these
      allow read, write: if false;
    }

    // Legacy: old unencrypted profile photos (migration)
    match /profiles/{userId}/{allPaths=**} {
      allow read: if isAuthenticated()
        && (request.auth.uid == userId || isAdmin());
      allow write: if isAuthenticated()
        && request.auth.uid == userId
        && isImage()
        && request.resource.size < maxSize();
    }

    // ───────────────────────────────────────────────
    // Chat Images
    // Only chat participants can read/write
    // ───────────────────────────────────────────────
    match /chats/{chatId}/{allPaths=**} {
      allow read: if isAuthenticated()
        && (isChatParticipant(chatId) || isAdmin());
      allow write: if isAuthenticated()
        && isChatParticipant(chatId)
        && isImage()
        && request.resource.size < maxSize();
    }

    // ───────────────────────────────────────────────
    // Delivery Item Photos
    // Sender uploads item photo when creating delivery
    // ───────────────────────────────────────────────
    match /deliveries/{senderId}/{allPaths=**} {
      // Owner or admin can read delivery media
      allow read: if isAuthenticated()
        && (request.auth.uid == senderId || isAdmin());
      allow write: if isAuthenticated()
        && request.auth.uid == senderId
        && isMedia()
        && request.resource.size < maxSize();
    }

    // ───────────────────────────────────────────────
    // Delivery Proof Photos
    // Only delivery participants (sender/driver) can read/write
    // ───────────────────────────────────────────────
    match /deliveries/{deliveryId}/proof/{allPaths=**} {
      allow read: if isAuthenticated()
        && (isDeliveryParticipant(deliveryId) || isAdmin());
      allow write: if isAuthenticated()
        && isDeliveryParticipant(deliveryId)
        && isImage()
        && request.resource.size < maxSize();
    }

    // ───────────────────────────────────────────────
    // KYC Documents — Encrypted at rest
    // Owner uploads temp, Cloud Function encrypts.
    // ───────────────────────────────────────────────
    match /kyc/{userId}/temp/{allPaths=**} {
      allow write: if isAuthenticated()
        && request.auth.uid == userId
        && isImage()
        && request.resource.size < maxSize();
      allow read: if false;
    }

    match /kyc/{userId}/encrypted/{allPaths=**} {
      // Only Cloud Functions (admin SDK)
      allow read, write: if false;
    }

    // Legacy KYC path
    match /kyc/{userId}/{allPaths=**} {
      allow write: if isAuthenticated()
        && request.auth.uid == userId
        && isImage()
        && request.resource.size < maxSize();
      allow read: if isAuthenticated()
        && (request.auth.uid == userId || isAdmin());
    }
  }
}
