# Mooviz Mobile — Environment Configuration
# Copy this file to .env.dev, .env.staging, or .env.prod and fill in values.
# NEVER commit actual .env files — only .env.example is tracked.

FIREBASE_API_KEY=your-api-key
FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
FIREBASE_PROJECT_ID=your-project-id
FIREBASE_STORAGE_BUCKET=your-project.firebasestorage.app
FIREBASE_MESSAGING_SENDER_ID=000000000000
FIREBASE_APP_ID=1:000000000000:web:xxxxxxxxxxxx
FIREBASE_IOS_APP_ID=1:000000000000:ios:xxxxxxxxxxxx
FIREBASE_ANDROID_APP_ID=1:000000000000:android:xxxxxxxxxxxx
GOOGLE_MAPS_API_KEY=your-google-maps-api-key
