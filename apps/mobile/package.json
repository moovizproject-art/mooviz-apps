{
  "name": "@mooviz/mobile",
  "version": "0.9.5",
  "private": true,
  "main": "index.js",
  "scripts": {
    "start": "react-native start",
    "start:8090": "react-native start --port 8090",
    "android": "react-native run-android",
    "ios": "react-native run-ios",
    "test": "jest",
    "lint": "eslint . --ext .ts,.tsx",
    "typecheck": "tsc --noEmit",
    "clean": "cd android && ./gradlew clean && cd .. && cd ios && xcodebuild clean && cd .."
  },
  "dependencies": {
    "@mooviz/shared": "workspace:*",
    "@notifee/react-native": "^7.8.0",
    "@react-native-async-storage/async-storage": "^1.24.0",
    "@react-native-community/datetimepicker": "^8.6.0",
    "@react-native-community/netinfo": "^11.3.0",
    "@react-native-community/slider": "^4.5.7",
    "@react-native-firebase/analytics": "^21.14.0",
    "@react-native-firebase/app": "^21.6.1",
    "@react-native-firebase/auth": "^21.6.1",
    "@react-native-firebase/crashlytics": "^21.14.0",
    "@react-native-firebase/firestore": "^21.6.1",
    "@react-native-firebase/functions": "^21.6.1",
    "@react-native-firebase/messaging": "^21.6.1",
    "@react-native-firebase/storage": "^21.6.1",
    "@react-navigation/bottom-tabs": "^6.5.11",
    "@react-navigation/native": "^6.1.9",
    "@react-navigation/native-stack": "^6.9.17",
    "ngeohash": "^0.6.3",
    "react": "18.2.0",
    "react-native": "0.75.5",
    "react-native-compressor": "^1.16.0",
    "react-native-config": "^1.5.1",
    "react-native-geolocation-service": "^5.3.1",
    "react-native-gesture-handler": "^2.16.0",
    "react-native-google-places-autocomplete": "^2.6.4",
    "react-native-image-picker": "^7.1.0",
    "react-native-maps": "^1.10.3",
    "react-native-reanimated": "^3.8.0",
    "react-native-restart": "^0.0.27",
    "react-native-safe-area-context": "^4.9.0",
    "react-native-screens": "^3.30.0",
    "react-native-sound": "^0.11.2",
    "react-native-video": "6.7.0"
  },
  "devDependencies": {
    "@babel/core": "^7.23.0",
    "@babel/runtime": "^7.23.0",
    "@react-native/babel-preset": "0.75.5",
    "@react-native/metro-config": "0.75.5",
    "@react-native/typescript-config": "0.75.5",
    "@testing-library/react-native": "^12.4.0",
    "@types/react": "~18.2.79",
    "@types/react-native": "~0.73.0",
    "babel-plugin-module-resolver": "^5.0.0",
    "jest": "^29.7.0",
    "metro-react-native-babel-preset": "^0.77.0",
    "react-test-renderer": "18.2.0",
    "typescript": "^5.9.3"
  },
  "jest": {
    "preset": "react-native",
    "moduleNameMapper": {
      "^@/(.*)$": "<rootDir>/src/$1"
    },
    "transformIgnorePatterns": [
      "node_modules/(?!(@react-native|react-native|@react-navigation|react-native-maps|react-native-reanimated|react-native-gesture-handler|react-native-screens|react-native-safe-area-context|@react-native-firebase|ngeohash|@notifee|react-native-geolocation-service|react-native-image-picker|react-native-config|@react-native-community)/)"
    ],
    "setupFiles": [
      "./jest.setup.js"
    ]
  },
  "engines": {
    "node": ">=18"
  }
}
