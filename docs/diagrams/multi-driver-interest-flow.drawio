        <mxCell id="a_s5" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;html=1;strokeWidth=2;strokeColor=#1a73e8;" edge="1" parent="1" source="s_tap_profile" target="s_select">
