        </mxCell>
        <mxCell id="a_s6" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;html=1;strokeWidth=2;strokeColor=#1a73e8;" edge="1" parent="1" source="s_select" target="s_wait_confirm">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="a_s7" value="אישר ✓" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;html=1;strokeWidth=2;strokeColor=#22c55e;fontFamily=Arial;fontSize=12;fontColor=#22c55e;" edge="1" parent="1" source="s_decision" target="s_waiting">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="a_s8" value="דחה / תם זמן ✗" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;html=1;strokeWidth=2;strokeColor=#EF4444;fontFamily=Arial;fontSize=12;fontColor=#EF4444;exitX=0;exitY=0.5;exitDx=0;exitDy=0;" edge="1" parent="1" source="s_decision" target="s_strikethrough">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="a_s9" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;html=1;strokeWidth=2;strokeColor=#EF4444;dashed=1;" edge="1" parent="1" source="s_strikethrough" target="s_view_list">
          <mxGeometry relative="1" as="geometry">
            <Array as="points">
              <mxPoint x="50" y="1040" />
              <mxPoint x="50" y="470" />
            </Array>
          </mxGeometry>
        </mxCell>
        <mxCell id="a_s6b" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;html=1;strokeWidth=2;strokeColor=#1a73e8;" edge="1" parent="1" source="s_wait_confirm" target="s_decision">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <!-- Cancel after waiting -->
        <mxCell id="a_s10" value="ביטול נהג (מו&quot;מ כושל)" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;html=1;strokeWidth=2;strokeColor=#EF4444;dashed=1;fontFamily=Arial;fontSize=11;fontColor=#EF4444;exitX=0;exitY=0.5;exitDx=0;exitDy=0;" edge="1" parent="1" source="s_waiting" target="s_strikethrough">
          <mxGeometry relative="1" as="geometry">
            <Array as="points">
