        <mxCell id="a_u5" value="נהג אחר נבחר" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;html=1;strokeWidth=2;strokeColor=#6b7280;fontFamily=Arial;fontSize=12;fontColor=#6b7280;exitX=1;exitY=0.5;exitDx=0;exitDy=0;" edge="1" parent="1" source="u_outcome" target="u_disappears">
