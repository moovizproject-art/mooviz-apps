<?xml version="1.0" encoding="UTF-8"?>
<mxfile host="Electron">
  <diagram name="Multi-Driver Interest Flow" id="multi-driver-flow-1">
    <mxGraphModel dx="1600" dy="1400" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="0" pageScale="1" pageWidth="1600" pageHeight="2000" math="0" shadow="0" defaultFontFamily="Arial">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />

        <!-- ═══════════════════════════════════════════ -->
        <!-- SWIM LANE BACKGROUNDS                       -->
        <!-- ═══════════════════════════════════════════ -->
        <mxCell id="lane_sender" value=""
          style="swimlane;startSize=0;fillColor=#E8F0FE;strokeColor=#1a73e8;opacity=30;rounded=1;"
          vertex="1" parent="1">
          <mxGeometry x="20" y="80" width="420" height="1320" as="geometry" />
        </mxCell>
        <mxCell id="lane_selected" value=""
          style="swimlane;startSize=0;fillColor=#E6F4EA;strokeColor=#22c55e;opacity=30;rounded=1;"
          vertex="1" parent="1">
          <mxGeometry x="460" y="80" width="420" height="1320" as="geometry" />
        </mxCell>
        <mxCell id="lane_unselected" value=""
          style="swimlane;startSize=0;fillColor=#F3F4F6;strokeColor=#6b7280;opacity=30;rounded=1;"
          vertex="1" parent="1">
          <mxGeometry x="900" y="80" width="420" height="1320" as="geometry" />
        </mxCell>

        <!-- ═══════════════════════════════════════════ -->
        <!-- TITLE                                       -->
        <!-- ═══════════════════════════════════════════ -->
        <mxCell id="title" value="MOOVIZ — תהליך מערכת ריבוי נהגים מעוניינים"
          style="text;html=1;align=center;verticalAlign=middle;fontFamily=Arial;fontSize=22;fontStyle=1;fontColor=#1e3a5f;"
          vertex="1" parent="1">
          <mxGeometry x="300" y="10" width="740" height="40" as="geometry" />
        </mxCell>

        <!-- LANE HEADERS -->
        <mxCell id="header_sender" value="שולח (Sender)"
          style="text;html=1;align=center;verticalAlign=middle;fontFamily=Arial;fontSize=18;fontStyle=1;fontColor=#FFFFFF;fillColor=#1a73e8;rounded=1;strokeColor=none;"
          vertex="1" parent="1">
          <mxGeometry x="80" y="90" width="300" height="40" as="geometry" />
        </mxCell>
        <mxCell id="header_selected" value="נהג נבחר (Selected Driver)"
          style="text;html=1;align=center;verticalAlign=middle;fontFamily=Arial;fontSize=18;fontStyle=1;fontColor=#FFFFFF;fillColor=#22c55e;rounded=1;strokeColor=none;"
          vertex="1" parent="1">
          <mxGeometry x="520" y="90" width="300" height="40" as="geometry" />
        </mxCell>
        <mxCell id="header_unselected" value="נהג לא נבחר (Other Driver)"
