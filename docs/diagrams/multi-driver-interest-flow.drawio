        <mxCell id="a_s1" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;html=1;strokeWidth=2;strokeColor=#1a73e8;" edge="1" parent="1" source="s_create" target="s_status_new">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="a_s2" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;html=1;strokeWidth=2;strokeColor=#1a73e8;" edge="1" parent="1" source="s_status_new" target="s_drivers_arrive">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="a_s3" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;html=1;strokeWidth=2;strokeColor=#1a73e8;" edge="1" parent="1" source="s_drivers_arrive" target="s_view_list">
          <mxGeometry relative="1" as="geometry" />
