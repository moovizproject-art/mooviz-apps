        </mxCell>
        <mxCell id="a_d3" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;html=1;strokeWidth=2;strokeColor=#22c55e;" edge="1" parent="1" source="d_notified" target="d_confirm_decision">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="a_d4" value="מאשר ✓" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;html=1;strokeWidth=2;strokeColor=#22c55e;fontFamily=Arial;fontSize=12;fontColor=#22c55e;" edge="1" parent="1" source="d_confirm_decision" target="d_assigned">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="a_d5" value="דוחה ✗" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;html=1;strokeWidth=2;strokeColor=#EF4444;fontFamily=Arial;fontSize=12;fontColor=#EF4444;exitX=0;exitY=0.5;exitDx=0;exitDy=0;" edge="1" parent="1" source="d_confirm_decision" target="d_declined">
