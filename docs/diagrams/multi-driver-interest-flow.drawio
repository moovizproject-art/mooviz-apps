        <mxCell id="a_s4" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;html=1;strokeWidth=2;strokeColor=#1a73e8;" edge="1" parent="1" source="s_view_list" target="s_tap_profile">
