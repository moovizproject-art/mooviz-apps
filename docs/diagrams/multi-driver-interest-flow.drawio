              <mxPoint x="100" y="1040" />
            </Array>
          </mxGeometry>
        </mxCell>

        <!-- Cross-lane: sender selects → driver gets notified -->
        <mxCell id="a_cross1" value="🔔 השולח בחר בך!" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;html=1;strokeWidth=2;strokeColor=#F59E0B;dashed=1;fontFamily=Arial;fontSize=12;fontColor=#F59E0B;" edge="1" parent="1" source="s_select" target="d_notified">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <!-- Selected driver flow -->
        <mxCell id="a_d1" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;html=1;strokeWidth=2;strokeColor=#22c55e;" edge="1" parent="1" source="d_sees_feed" target="d_express">
