<?xml version="1.0" encoding="UTF-8"?>
<mxfile host="Electron">
  <diagram name="Firestore Data Model" id="mooviz-erd-1">
    <mxGraphModel dx="1400" dy="1000" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="0" pageScale="1" pageWidth="1400" pageHeight="1000" math="0" shadow="0" defaultFontFamily="Helvetica">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />

        <!-- ARROWS FIRST -->
        <!-- deliveries.senderId → users -->
        <mxCell id="r1" value="senderId" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;strokeWidth=2;fontFamily=Helvetica;fontSize=11;startArrow=ERmany;startFill=0;endArrow=ERone;endFill=0;exitX=0;exitY=0.25;exitDx=0;exitDy=0;entryX=1;entryY=0.25;entryDx=0;entryDy=0;" edge="1" parent="1" source="deliveries" target="users">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <!-- deliveries.driverId → users -->
        <mxCell id="r2" value="driverId" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;strokeWidth=2;fontFamily=Helvetica;fontSize=11;startArrow=ERmany;startFill=0;endArrow=ERone;endFill=0;exitX=0;exitY=0.5;exitDx=0;exitDy=0;entryX=1;entryY=0.5;entryDx=0;entryDy=0;" edge="1" parent="1" source="deliveries" target="users">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <!-- chats → deliveries -->
        <mxCell id="r3" value="1:1 per delivery" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;strokeWidth=2;fontFamily=Helvetica;fontSize=11;startArrow=ERone;startFill=0;endArrow=ERone;endFill=0;" edge="1" parent="1" source="chats" target="deliveries">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <!-- ratings → deliveries -->
        <mxCell id="r4" value="deliveryId" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;strokeWidth=2;fontFamily=Helvetica;fontSize=11;startArrow=ERmany;startFill=0;endArrow=ERone;endFill=0;exitX=0.5;exitY=0;exitDx=0;exitDy=0;entryX=0.5;entryY=1;entryDx=0;entryDy=0;" edge="1" parent="1" source="ratings" target="deliveries">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <!-- ratings → users -->
        <mxCell id="r5" value="raterId / ratedUserId" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;strokeWidth=2;fontFamily=Helvetica;fontSize=11;startArrow=ERmany;startFill=0;endArrow=ERone;endFill=0;exitX=0;exitY=0.5;exitDx=0;exitDy=0;entryX=0.5;entryY=1;entryDx=0;entryDy=0;" edge="1" parent="1" source="ratings" target="users">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <!-- reports → users -->
        <mxCell id="r6" value="reportedUserId" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;strokeWidth=2;fontFamily=Helvetica;fontSize=11;startArrow=ERmany;startFill=0;endArrow=ERone;endFill=0;exitX=0;exitY=0.25;exitDx=0;exitDy=0;entryX=0;entryY=1;entryDx=0;entryDy=0;" edge="1" parent="1" source="reports" target="users">
          <mxGeometry relative="1" as="geometry">
            <Array as="points">
              <mxPoint x="40" y="718" />
              <mxPoint x="40" y="450" />
            </Array>
          </mxGeometry>
        </mxCell>
        <!-- adminActions → users/deliveries -->
        <mxCell id="r7" value="targetId" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;strokeWidth=1;dashed=1;fontFamily=Helvetica;fontSize=11;strokeColor=#999999;" edge="1" parent="1" source="adminActions" target="deliveries">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <!-- messages subcollection indicator -->
        <mxCell id="r8" value="subcollection" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;strokeWidth=2;fontFamily=Helvetica;fontSize=11;dashed=1;strokeColor=#6c8ebf;" edge="1" parent="1" source="chats" target="messages">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <!-- TITLE -->
        <mxCell id="title" value="MOOVIZ — Firestore Data Model (ERD)" style="text;html=1;align=left;verticalAlign=middle;fontFamily=Helvetica;fontSize=24;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="40" y="20" width="500" height="40" as="geometry" />
        </mxCell>

        <!-- USERS COLLECTION -->
        <mxCell id="users" value="&lt;b&gt;users/{userId}&lt;/b&gt;&lt;hr&gt;uid: string&lt;br&gt;fullName: string&lt;br&gt;phone: string (E.164)&lt;br&gt;email: string?&lt;br&gt;city: string&lt;br&gt;role: sender | driver&lt;br&gt;profilePhotoURL: string&lt;br&gt;kycDocumentURL: string&lt;br&gt;kycStatus: pending | approved | rejected&lt;br&gt;rating: { average, count }&lt;br&gt;completedDeliveries: number&lt;br&gt;status: active | suspended | blocked&lt;br&gt;fcmToken: string&lt;br&gt;location: { lat, lng, geohash }&lt;br&gt;createdAt: Timestamp" style="rounded=0;whiteSpace=wrap;html=1;fontFamily=Helvetica;fontSize=12;fillColor=#dae8fc;strokeColor=#6c8ebf;align=left;verticalAlign=top;spacingLeft=8;spacingTop=4;" vertex="1" parent="1">
          <mxGeometry x="60" y="80" width="260" height="370" as="geometry" />
        </mxCell>

        <!-- DELIVERIES COLLECTION -->
        <mxCell id="deliveries" value="&lt;b&gt;deliveries/{deliveryId}&lt;/b&gt;&lt;hr&gt;senderId: string → users&lt;br&gt;driverId: string? → users&lt;br&gt;status: new | pending | waiting |&lt;br&gt;  picked_up | delivered | cancelled |&lt;br&gt;  completed_paid&lt;br&gt;pickup: { address, city, lat, lng, geohash }&lt;br&gt;destination: { address, city, lat, lng, geohash }&lt;br&gt;item: { description, type, size, photoURL }&lt;br&gt;price: number (NIS)&lt;br&gt;pickupDate: Timestamp | asap&lt;br&gt;notes: string?&lt;br&gt;payment: { senderConfirmed, driverConfirmed }&lt;br&gt;proof: { pickupURL, deliveryURL, paymentURL }&lt;br&gt;statusHistory: [{ status, actor, timestamp }]&lt;br&gt;cancelledBy: string?&lt;br&gt;timeoutAt: Timestamp&lt;br&gt;createdAt / updatedAt: Timestamp" style="rounded=0;whiteSpace=wrap;html=1;fontFamily=Helvetica;fontSize=12;fillColor=#fff2cc;strokeColor=#d6b656;align=left;verticalAlign=top;spacingLeft=8;spacingTop=4;" vertex="1" parent="1">
          <mxGeometry x="420" y="80" width="300" height="420" as="geometry" />
        </mxCell>

        <!-- CHATS COLLECTION -->
        <mxCell id="chats" value="&lt;b&gt;chats/{deliveryId}&lt;/b&gt;&lt;hr&gt;participants: [senderId, driverId]&lt;br&gt;lastMessage: { text, sender, ts }&lt;br&gt;unreadCount: { [userId]: number }" style="rounded=0;whiteSpace=wrap;html=1;fontFamily=Helvetica;fontSize=12;fillColor=#d5e8d4;strokeColor=#82b366;align=left;verticalAlign=top;spacingLeft=8;spacingTop=4;" vertex="1" parent="1">
          <mxGeometry x="820" y="80" width="260" height="120" as="geometry" />
        </mxCell>

        <!-- MESSAGES SUBCOLLECTION -->
        <mxCell id="messages" value="&lt;b&gt;messages/{messageId}&lt;/b&gt;&lt;br&gt;&lt;i&gt;(subcollection of chats)&lt;/i&gt;&lt;hr&gt;senderId: string&lt;br&gt;type: text | image | system | proof&lt;br&gt;text: string&lt;br&gt;imageURL: string?&lt;br&gt;proofType: pickup | delivery | payment&lt;br&gt;metadata: { deliveryId, uploadedBy }&lt;br&gt;createdAt: Timestamp" style="rounded=0;whiteSpace=wrap;html=1;fontFamily=Helvetica;fontSize=12;fillColor=#d5e8d4;strokeColor=#82b366;align=left;verticalAlign=top;spacingLeft=8;spacingTop=4;dashed=1;" vertex="1" parent="1">
          <mxGeometry x="820" y="250" width="260" height="200" as="geometry" />
        </mxCell>

        <!-- RATINGS COLLECTION -->
        <mxCell id="ratings" value="&lt;b&gt;ratings/{ratingId}&lt;/b&gt;&lt;hr&gt;deliveryId: string → deliveries&lt;br&gt;raterId: string → users&lt;br&gt;ratedUserId: string → users&lt;br&gt;score: number (1-5)&lt;br&gt;comment: string? (max 300)&lt;br&gt;createdAt: Timestamp" style="rounded=0;whiteSpace=wrap;html=1;fontFamily=Helvetica;fontSize=12;fillColor=#e1d5e7;strokeColor=#9673a6;align=left;verticalAlign=top;spacingLeft=8;spacingTop=4;" vertex="1" parent="1">
          <mxGeometry x="420" y="560" width="260" height="170" as="geometry" />
        </mxCell>

        <!-- REPORTS COLLECTION -->
        <mxCell id="reports" value="&lt;b&gt;reports/{reportId}&lt;/b&gt;&lt;hr&gt;reporterId: string → users&lt;br&gt;reportedUserId: string → users&lt;br&gt;deliveryId: string?&lt;br&gt;type: string (5+ types)&lt;br&gt;description: string&lt;br&gt;status: new | investigating | resolved&lt;br&gt;adminNotes: [{ note, adminId, ts }]&lt;br&gt;createdAt: Timestamp" style="rounded=0;whiteSpace=wrap;html=1;fontFamily=Helvetica;fontSize=12;fillColor=#f8cecc;strokeColor=#b85450;align=left;verticalAlign=top;spacingLeft=8;spacingTop=4;" vertex="1" parent="1">
          <mxGeometry x="60" y="560" width="260" height="210" as="geometry" />
        </mxCell>

        <!-- ADMIN ACTIONS COLLECTION -->
        <mxCell id="adminActions" value="&lt;b&gt;adminActions/{actionId}&lt;/b&gt;&lt;hr&gt;adminId: string&lt;br&gt;action: string (block_user, etc.)&lt;br&gt;targetType: user | delivery | rating&lt;br&gt;targetId: string&lt;br&gt;details: map&lt;br&gt;createdAt: Timestamp" style="rounded=0;whiteSpace=wrap;html=1;fontFamily=Helvetica;fontSize=12;fillColor=#f5f5f5;strokeColor=#666666;align=left;verticalAlign=top;spacingLeft=8;spacingTop=4;" vertex="1" parent="1">
          <mxGeometry x="780" y="560" width="260" height="170" as="geometry" />
        </mxCell>

      </root>
    </mxGraphModel>
  </diagram>
</mxfile>
