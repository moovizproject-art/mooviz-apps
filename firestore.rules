rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Helper: check if the requesting user is an admin
    function isAdmin() {
      return request.auth != null
        && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role in ['admin', 'moderator'];
    }

    // Helper: check if user is authenticated
    function isAuthenticated() {
      return request.auth != null;
    }

    // Helper: check if user owns the document
    function isOwner(userId) {
      return request.auth != null && request.auth.uid == userId;
    }

    // Fields that clients must never write directly
    // (only Cloud Functions can set these)
    function noProtectedFields() {
      return !request.resource.data.diff(resource.data).affectedKeys()
        .hasAny(['role', 'status', 'kycStatus', 'driverUnlocked',
                 'profilePhotoPath', 'profilePhotoUpdatedAt',
                 'ratingAsDriver', 'ratingAsSender', 'completedDeliveries']);
    }

    // ───────────────────────────────────────────────
    // Users
    // ───────────────────────────────────────────────
    match /users/{userId} {
      // Bootstrap: allow initial admin doc creation (remove after setup)
      allow create: if request.auth != null
        && request.auth.uid == 'np59JHWkCveavp2ldfio5njBqvJ2'
        && userId == 'np59JHWkCveavp2ldfio5njBqvJ2';

      // Owner can read own profile; admins can read all
      allow read: if isOwner(userId) || isAdmin();

      // Delivery participants can read limited sender/driver info
      // (Cloud Function handles photo access separately)
      allow read: if isAuthenticated();

      // Users can write their own profile (restricted fields)
      allow create: if isOwner(userId);
      allow update: if isOwner(userId) && noProtectedFields();

      // Admins can do anything
      allow create, update: if isAdmin();
      allow delete: if isAdmin();
    }

    // ───────────────────────────────────────────────
    // Deliveries
    // ───────────────────────────────────────────────
    match /deliveries/{deliveryId} {
      // Sender can create a delivery
      allow create: if isAuthenticated()
        && request.resource.data.senderId == request.auth.uid
        && request.resource.data.status == 'new';

      // Sender can read their own deliveries
      allow read: if isAuthenticated()
        && resource.data.senderId == request.auth.uid;

      // Driver can read available deliveries (status == 'new') or assigned
      allow read: if isAuthenticated()
        && (resource.data.status == 'new' || resource.data.driverId == request.auth.uid);

      // Sender can update their own deliveries (approve driver, confirm payment, cancel)
      allow update: if isAuthenticated()
        && resource.data.senderId == request.auth.uid;

      // Driver can update assigned deliveries (pickup, deliver, confirm payment)
      allow update: if isAuthenticated()
        && resource.data.driverId == request.auth.uid;

      // Any authenticated user can express interest (adds to interestedDrivers)
      allow update: if isAuthenticated()
        && resource.data.status == 'new';

      // Admins can read/write all
      allow read: if isAdmin();
      allow create, update: if isAdmin();
      allow delete: if isAdmin();
    }

    // ───────────────────────────────────────────────
    // Chats
    // ───────────────────────────────────────────────
    match /chats/{chatId} {
      // Single doc read/write: user must be a participant
      allow get: if isAuthenticated()
        && request.auth.uid in resource.data.participants;
      // Collection list: allow — array-contains query ensures only own chats returned
      allow list: if isAuthenticated();
      allow write: if isAuthenticated()
        && request.auth.uid in resource.data.participants;

      allow create: if isAuthenticated()
        && request.auth.uid in request.resource.data.participants;

      // Admins can read/write all chats
      allow read, create, update, delete: if isAdmin();

      match /messages/{messageId} {
        allow read, write: if isAuthenticated()
          && request.auth.uid in get(/databases/$(database)/documents/chats/$(chatId)).data.participants;

        // Admins can read/write all messages
        allow read, write: if isAdmin();
      }
    }

    // ───────────────────────────────────────────────
    // Ratings
    // ───────────────────────────────────────────────
    match /ratings/{ratingId} {
      allow create: if isAuthenticated()
        && request.resource.data.fromUserId == request.auth.uid;
      allow read: if true;
      allow update, delete: if isAdmin();
    }

    // ───────────────────────────────────────────────
    // Reports
    // ───────────────────────────────────────────────
    match /reports/{reportId} {
      allow create: if isAuthenticated()
        && request.resource.data.reporterId == request.auth.uid;
      allow read, update, delete: if isAdmin();
    }

    // ───────────────────────────────────────────────
    // Admin Actions — admin only
    // ───────────────────────────────────────────────
    match /adminActions/{actionId} {
      allow read, write: if isAdmin();
    }

    // ───────────────────────────────────────────────
    // Config — admin only
    // ───────────────────────────────────────────────
    match /config/{configId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }
  }
}
