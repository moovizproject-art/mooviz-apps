rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Helper: check if the requesting user is an admin
    function isAdmin() {
      return request.auth != null
        && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role in ['admin', 'moderator'];
    }

    // Helper: check if user is authenticated
    function isAuthenticated() {
      return request.auth != null;
    }

    // Helper: check if user owns the document
    function isOwner(userId) {
      return request.auth != null && request.auth.uid == userId;
    }

    // Fields that clients must never write directly
    // (only Cloud Functions can set these)
    function noProtectedFields() {
      return !request.resource.data.diff(resource.data).affectedKeys()
        .hasAny(['role', 'status', 'kycStatus', 'driverUnlocked',
                 'profilePhotoPath', 'profilePhotoUpdatedAt',
                 'ratingAsDriver', 'ratingAsSender', 'completedDeliveries']);
    }

    // Allowed fields for user self-update
    function allowedUserUpdateFields() {
      return request.resource.data.diff(resource.data).affectedKeys()
        .hasOnly(['fullName', 'phone', 'city', 'activeMode',
                  'fcmToken', 'fcmTokens', 'location', 'updatedAt',
                  'driverSettings', 'notificationSettings']);
    }

    // Allowed fields for delivery sender updates
    function allowedSenderDeliveryFields() {
      return request.resource.data.diff(resource.data).affectedKeys()
        .hasOnly(['status', 'driverId', 'interestedDrivers',
                  'payment', 'cancelledBy', 'updatedAt', 'proof']);
    }

    // Allowed fields for delivery driver updates
    function allowedDriverDeliveryFields() {
      return request.resource.data.diff(resource.data).affectedKeys()
        .hasOnly(['status', 'interestedDrivers', 'payment',
                  'proof', 'updatedAt']);
    }

    // Restrict role to sender/driver only (no admin self-promotion)
    function validRole() {
      return request.resource.data.role in ['sender', 'driver'];
    }

    // ───────────────────────────────────────────────
    // Users
    // ───────────────────────────────────────────────
    match /users/{userId} {
      // Owner can read own full profile
      allow read: if isOwner(userId);

      // Authenticated users can read public fields of other users
      // (Firestore doesn't support field-level rules, so we allow read
      //  but the client/Cloud Functions control which fields are exposed)
      allow read: if isAuthenticated();

      // Users can create their own profile with valid role only
      allow create: if isOwner(userId) && validRole();

      // Users can update their own profile (restricted fields only)
      allow update: if isOwner(userId) && noProtectedFields() && allowedUserUpdateFields();

      // Admins can read/write all
      allow read, create, update: if isAdmin();
      allow delete: if isAdmin();
    }

    // ───────────────────────────────────────────────
    // Deliveries
    // ───────────────────────────────────────────────
    match /deliveries/{deliveryId} {
      // Sender can create a delivery
      allow create: if isAuthenticated()
        && request.resource.data.senderId == request.auth.uid
        && request.resource.data.status == 'new';

      // Sender can read their own deliveries
      allow read: if isAuthenticated()
        && resource.data.senderId == request.auth.uid;

      // Driver can read available deliveries (new/pending) or assigned
      allow read: if isAuthenticated()
        && (resource.data.status in ['new', 'pending'] || resource.data.driverId == request.auth.uid);

      // Sender can update their own deliveries (restricted fields)
      allow update: if isAuthenticated()
        && resource.data.senderId == request.auth.uid
        && allowedSenderDeliveryFields();

      // Driver can update assigned deliveries (restricted fields)
      allow update: if isAuthenticated()
        && resource.data.driverId == request.auth.uid
        && allowedDriverDeliveryFields();

      // Any authenticated user can express interest on new deliveries
      allow update: if isAuthenticated()
        && resource.data.status == 'new'
        && request.resource.data.diff(resource.data).affectedKeys()
          .hasOnly(['interestedDrivers', 'updatedAt']);

      // Admins can read/write all
      allow read: if isAdmin();
      allow create, update: if isAdmin();
      allow delete: if isAdmin();
    }

    // ───────────────────────────────────────────────
    // Chats
    // ───────────────────────────────────────────────
    match /chats/{chatId} {
      // Single doc read/write: user must be a participant
      allow get: if isAuthenticated()
        && request.auth.uid in resource.data.participants;

      // Collection list: only when queried with array-contains for own UID
      allow list: if isAuthenticated();

      allow write: if isAuthenticated()
        && request.auth.uid in resource.data.participants;

      allow create: if isAuthenticated()
        && request.auth.uid in request.resource.data.participants;

      // Admins can read/write all chats
      allow read, create, update, delete: if isAdmin();

      match /messages/{messageId} {
        allow read, write: if isAuthenticated()
          && request.auth.uid in get(/databases/$(database)/documents/chats/$(chatId)).data.participants;

        // Admins can read/write all messages
        allow read, write: if isAdmin();
      }
    }

    // ───────────────────────────────────────────────
    // Ratings
    // ───────────────────────────────────────────────
    match /ratings/{ratingId} {
      allow create: if isAuthenticated()
        && request.resource.data.fromUserId == request.auth.uid;
      allow read: if true;
      allow update, delete: if isAdmin();
    }

    // ───────────────────────────────────────────────
    // Reports
    // ───────────────────────────────────────────────
    match /reports/{reportId} {
      allow create: if isAuthenticated()
        && request.resource.data.reporterId == request.auth.uid;
      allow read, update, delete: if isAdmin();
    }

    // ───────────────────────────────────────────────
    // Admin Actions — admin only
    // ───────────────────────────────────────────────
    match /adminActions/{actionId} {
      allow read, write: if isAdmin();
    }

    // ───────────────────────────────────────────────
    // Config — admin only
    // ───────────────────────────────────────────────
    match /config/{configId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }
  }
}
