{
  "name": "mooviz",
  "private": true,
  "version": "0.1.0",
  "workspaces": [
    "apps/*",
    "functions",
    "shared"
  ],
  "scripts": {
    "dev:mobile": "turbo run dev --filter=@mooviz/mobile",
    "dev:admin": "turbo run dev --filter=@mooviz/admin",
    "dev:functions": "turbo run dev --filter=@mooviz/functions",
    "build": "turbo run build",
    "lint": "turbo run lint",
    "test": "turbo run test",
    "deploy:functions": "firebase deploy --only functions",
    "deploy:admin": "firebase deploy --only hosting"
  },
  "devDependencies": {
    "turbo": "^2.0.0"
  },
  "packageManager": "pnpm@9.0.0",
  "engines": {
    "node": ">=18.0.0"
  },
  "pnpm": {
    "overrides": {
      "react-native-reanimated": "3.15.5",
      "react-native-gesture-handler": "2.20.2",
      "react-native-maps": "1.18.2",
      "react-native-screens": "3.35.0",
      "react-native-safe-area-context": "4.12.0"
    }
  }
}
